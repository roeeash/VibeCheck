# VibeCheck API — Environment Variables

# Port the API server listens on
PORT=4000

# Node.js environment
NODE_ENV=production

# Logging verbosity: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Path where Playwright caches downloaded browsers (Chromium, Firefox, WebKit)
# In Docker, this should be /root/.cache/ms-playwright or similar
# On bare metal, this can be ~/.cache/ms-playwright
PLAYWRIGHT_BROWSERS_PATH=/root/.cache/ms-playwright

# Skip downloading browsers during npm install (assumes they're pre-installed or volume-mounted)
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
