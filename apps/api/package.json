{
  "name": "@vibecheck/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --outDir dist --external playwright --external pino",
    "build:bundle": "tsup src/server.ts --format esm --outDir ../../vibecheck-mcp/vendor --external playwright --external pino --external express --external cors --external pino-http",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vibecheck/core": "workspace:*",
    "@vibecheck/engine": "workspace:*",
    "@vibecheck/observer": "workspace:*",
    "@vibecheck/proxy": "workspace:*",
    "@vibecheck/asset-inspector": "workspace:*",
    "@vibecheck/render": "workspace:*",
    "@vibecheck/memory": "workspace:*",
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
