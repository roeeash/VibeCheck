{
  "name": "@vibecheck/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/server.ts",
    "dev:ui": "vite --config client/vite.config.ts",
    "dev": "concurrently -n api,ui -c cyan,magenta \"pnpm dev:api\" \"pnpm dev:ui\"",
    "start": "node dist/server.js",
    "build:api": "tsup src/server.ts --format esm --outDir dist --external playwright --external pino",
    "build:ui": "vite build --config client/vite.config.ts",
    "build": "pnpm build:ui && pnpm build:api",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vibecheck/core": "workspace:*",
    "@vibecheck/engine": "workspace:*",
    "@vibecheck/observer": "workspace:*",
    "@vibecheck/proxy": "workspace:*",
    "@vibecheck/asset-inspector": "workspace:*",
    "@vibecheck/render": "workspace:*",
    "@vibecheck/memory": "workspace:*",
    "archiver": "^7.0.0",
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
